{
  "//": "Kimchi Mart RTDB Security Rules — paste into Firebase Console",
  "//": "(Realtime Database → Rules → replace all → Publish).",
  "//": "Default deny. Approved users read/write only their own branch's",
  "//": "data; OWNER and EXECUTIVE bypass branch limits; MANAGER+ approve",
  "//": "users; everyone owns their own /users/{uid} record.",
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('role').val() === 'OWNER' || root.child('users').child(auth.uid).child('role').val() === 'EXECUTIVE' || root.child('users').child(auth.uid).child('role').val() === 'MANAGER' || root.child('users').child(auth.uid).child('role').val() === 'ASSISTANT_MANAGER' || root.child('users').child(auth.uid).child('role').val() === 'SUPERVISOR'))",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || (root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('role').val() === 'OWNER' || root.child('users').child(auth.uid).child('role').val() === 'EXECUTIVE' || root.child('users').child(auth.uid).child('role').val() === 'MANAGER' || root.child('users').child(auth.uid).child('role').val() === 'ASSISTANT_MANAGER' || root.child('users').child(auth.uid).child('role').val() === 'SUPERVISOR')))",
        ".write": "auth != null && (auth.uid === $uid && !data.exists() || auth.uid === $uid && newData.child('status').val() === data.child('status').val() && newData.child('role').val() === data.child('role').val() && newData.child('branch').val() === data.child('branch').val() || (root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('role').val() === 'OWNER' || root.child('users').child(auth.uid).child('role').val() === 'EXECUTIVE' || root.child('users').child(auth.uid).child('role').val() === 'MANAGER' || root.child('users').child(auth.uid).child('role').val() === 'ASSISTANT_MANAGER' || root.child('users').child(auth.uid).child('role').val() === 'SUPERVISOR')))"
      }
    },

    "expiry": {
      "$branch": {
        ".read":  "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('branch').val() === $branch || root.child('users').child(auth.uid).child('branch').val() === '*')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('branch').val() === $branch || root.child('users').child(auth.uid).child('branch').val() === '*')"
      }
    },

    "tasks": {
      "$branch": {
        ".read":  "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('branch').val() === $branch || root.child('users').child(auth.uid).child('branch').val() === '*')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('branch').val() === $branch || root.child('users').child(auth.uid).child('branch').val() === '*')"
      }
    },

    "temp": {
      "$branch": {
        ".read":  "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('branch').val() === $branch || root.child('users').child(auth.uid).child('branch').val() === '*')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('branch').val() === $branch || root.child('users').child(auth.uid).child('branch').val() === '*')"
      }
    },

    "products": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      "$branch": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('branch').val() === $branch || root.child('users').child(auth.uid).child('branch').val() === '*')"
      }
    },

    "schedules": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      "$branch": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('branch').val() === $branch || root.child('users').child(auth.uid).child('branch').val() === '*' || root.child('users').child(auth.uid).child('role').val() === 'MANAGER' || root.child('users').child(auth.uid).child('role').val() === 'ASSISTANT_MANAGER')"
      }
    },

    "chats": {
      ".read":  "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },

    "updates": {
      ".read":  "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('role').val() === 'OWNER' || root.child('users').child(auth.uid).child('role').val() === 'EXECUTIVE' || root.child('users').child(auth.uid).child('role').val() === 'MANAGER' || root.child('users').child(auth.uid).child('role').val() === 'ASSISTANT_MANAGER')"
    }
  }
}
